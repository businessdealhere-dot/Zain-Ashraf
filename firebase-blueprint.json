{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information captured during login.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string", "description": "User's first name" },
        "lastName": { "type": "string", "description": "User's last name" },
        "zipCode": { "type": "string", "description": "User's zip code" },
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User's email" }
      },
      "required": ["firstName", "lastName", "zipCode", "uid"]
    },
    "Order": {
      "title": "Order",
      "description": "Stores IPTV service orders.",
      "type": "object",
      "properties": {
        "clientName": { "type": "string", "description": "Full name of the client" },
        "zipCode": { "type": "string", "description": "Zip code for the order" },
        "selectedPlan": { "type": "string", "description": "The IPTV plan selected" },
        "deviceType": { "type": "string", "description": "The device type selected" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the order was placed" },
        "status": { "type": "string", "description": "Current status of the order" },
        "uid": { "type": "string", "description": "UID of the user who placed the order" }
      },
      "required": ["clientName", "zipCode", "selectedPlan", "deviceType", "timestamp", "status", "uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of all IPTV orders."
    }
  }
}
